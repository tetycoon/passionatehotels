<script>
document.addEventListener("click", function (e) {
  var btn = e.target.closest(".pum .enquiry-call");
  if (!btn) return;

  e.preventDefault();

  var number = btn.getAttribute("data-tel");
  if (!number) return;

  window.location.href = "tel:" + number.replace(/[^0-9+]/g, "");
});
